# Rename this file to hermes.env and replace the placeholder values with your own secrets.

TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
GATEWAY_ALLOW_ALL_USERS=true
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# You can also register several keys for switching. Example:
# GEMINI_API_KEYS=primary:YOUR_GEMINI_API_KEY_1,backup:YOUR_GEMINI_API_KEY_2
# GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# Optional API key limit metadata for the harness:
# API_KEY_LIMITS={"primary":1000000,"backup":500000}

# Optionally lock down access to specific Telegram user IDs
# TELEGRAM_ALLOWED_USERS=123456789
